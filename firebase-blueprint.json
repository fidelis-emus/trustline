{
  "entities": {
    "admin": {
      "title": "Admin",
      "description": "Administrator accounts",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["email", "password"]
    },
    "settings": {
      "title": "Settings",
      "description": "Site-wide settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "products": {
      "title": "Products",
      "description": "Investment products",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "min_investment": { "type": "number" },
        "expected_return": { "type": "number" },
        "duration_months": { "type": "number" },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "category": { "type": "string", "enum": ["fixed_income", "dollar", "portfolio"] },
        "image_url": { "type": "string" },
        "currency": { "type": "string" },
        "rating": { "type": "number" },
        "view_rate": { "type": "number" },
        "rate_3m": { "type": "number" },
        "rate_6m": { "type": "number" },
        "rate_12m": { "type": "number" }
      },
      "required": ["title", "description", "min_investment"]
    },
    "news": {
      "title": "News",
      "description": "News articles",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image_url": { "type": "string" },
        "published_date": { "type": "string" }
      },
      "required": ["title", "content"]
    },
    "team": {
      "title": "Team",
      "description": "Team members",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image_url": { "type": "string" },
        "category": { "type": "string", "enum": ["board", "management", "staff"] }
      },
      "required": ["name", "role", "category"]
    },
    "contacts": {
      "title": "Contacts",
      "description": "Contact messages",
      "type": "object",
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "is_read": { "type": "boolean" }
      },
      "required": ["first_name", "email", "message"]
    },
    "gallery": {
      "title": "Gallery",
      "description": "Gallery images",
      "type": "object",
      "properties": {
        "image_url": { "type": "string" },
        "caption": { "type": "string" }
      },
      "required": ["image_url"]
    },
    "staff_gallery": {
      "title": "Staff Gallery",
      "description": "Staff gallery images",
      "type": "object",
      "properties": {
        "image_url": { "type": "string" },
        "caption": { "type": "string" }
      },
      "required": ["image_url"]
    },
    "testimonials": {
      "title": "Testimonials",
      "description": "Client testimonials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["name", "content"]
    },
    "tailored_investments": {
      "title": "Tailored Investments",
      "description": "Tailored investment options",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image_url": { "type": "string" }
      },
      "required": ["title", "description"]
    }
  },
  "firestore": {
    "/admin/{adminId}": { "schema": "admin", "description": "Admin accounts" },
    "/settings/{settingId}": { "schema": "settings", "description": "Site settings" },
    "/products/{productId}": { "schema": "products", "description": "Investment products" },
    "/news/{newsId}": { "schema": "news", "description": "News articles" },
    "/team/{teamId}": { "schema": "team", "description": "Team members" },
    "/contacts/{contactId}": { "schema": "contacts", "description": "Contact messages" },
    "/gallery/{galleryId}": { "schema": "gallery", "description": "Gallery images" },
    "/staff_gallery/{staffGalleryId}": { "schema": "staff_gallery", "description": "Staff gallery images" },
    "/testimonials/{testimonialId}": { "schema": "testimonials", "description": "Client testimonials" },
    "/tailored_investments/{tailoredInvestmentId}": { "schema": "tailored_investments", "description": "Tailored investment options" }
  }
}
